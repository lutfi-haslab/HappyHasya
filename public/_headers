# Never cache sw.js to ensure immediate update detection on every refresh
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Never cache index.html to guarantee fingerprinted assets are always fresh
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Never cache manifest.json
/manifest.json
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Cache fingerprinted assets aggressively forever (as they contain a unique file hash)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
